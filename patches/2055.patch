From 19ea4de53df8cb0bb1fcd91b639b74149996cb1a Mon Sep 17 00:00:00 2001
From: Chenx Dust <chenx_dust@outlook.com>
Date: Sat, 30 May 2026 03:21:30 +0800
Subject: [PATCH] Fix Android build on Windows

---
 plugins/setup/buildkit/gradle/plugin.gradle | 7 +++++--
 1 file changed, 5 insertions(+), 2 deletions(-)

diff --git a/plugins/setup/buildkit/gradle/plugin.gradle b/plugins/setup/buildkit/gradle/plugin.gradle
index 9adfe08fc..62d3ac4cb 100644
--- a/plugins/setup/buildkit/gradle/plugin.gradle
+++ b/plugins/setup/buildkit/gradle/plugin.gradle
@@ -5,8 +5,11 @@
 //
 // It adds a task that runs build_tool android before mergeNativeLibs.
 
+import org.apache.tools.ant.taskdefs.condition.Os
+
 def buildkitDir = file("${project.projectDir}/../buildkit").absolutePath
-def launcher = "${buildkitDir}/run_build_tool.sh"
+def shell = Os.isFamily(Os.FAMILY_WINDOWS) ? 'cmd' : 'bash'
+def launcher = Os.isFamily(Os.FAMILY_WINDOWS) ? "${buildkitDir}\\run_build_tool.cmd" : "${buildkitDir}/run_build_tool.sh"
 def projectRoot = file("${buildkitDir}/../../..").absolutePath
 def androidArch = System.getenv('ANDROID_ARCH')
 def targetPlatform = project.findProperty('target-platform') ?:
@@ -18,7 +21,7 @@ def archArgs = androidArch
 
 task buildGoCore(type: Exec) {
     workingDir buildkitDir
-    commandLine 'bash', launcher, 'android', *archArgs
+    commandLine shell, launcher, 'android', *archArgs
 
     environment 'ANDROID_NDK', androidNdk
     environment 'APP_ENV', project.hasProperty('appEnv') ? project.appEnv : 'pre'
