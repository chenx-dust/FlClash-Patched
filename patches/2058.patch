From 2b5bbf49e6ad6ea0c31b3316505c12e6fa42a43a Mon Sep 17 00:00:00 2001
From: Chenx Dust <chenx_dust@outlook.com>
Date: Sat, 30 May 2026 04:20:07 +0800
Subject: [PATCH] Use 16KB page size for Android

---
 android/core/src/main/cpp/CMakeLists.txt             |  2 ++
 .../buildkit/build_tool/lib/src/go_builder.dart      | 12 +++++++++++-
 pubspec.lock                                         | 11 +++++------
 pubspec.yaml                                         |  5 +----
 4 files changed, 19 insertions(+), 11 deletions(-)

diff --git a/android/core/src/main/cpp/CMakeLists.txt b/android/core/src/main/cpp/CMakeLists.txt
index c9e22c98c..249dfc279 100644
--- a/android/core/src/main/cpp/CMakeLists.txt
+++ b/android/core/src/main/cpp/CMakeLists.txt
@@ -13,6 +13,8 @@ if (NOT "${CMAKE_BUILD_TYPE}" STREQUAL "Debug")
     add_link_options(-flto -Wl,--gc-sections,--strip-all)
 endif ()
 
+add_link_options(-Wl,-z,max-page-size=16384)
+
 set(LIB_CLASH_PATH "${CMAKE_SOURCE_DIR}/../jniLibs/${ANDROID_ABI}/libclash.so")
 set(LIB_CLASH_INCLUDE_DIR "${CMAKE_SOURCE_DIR}/../cpp/includes/${ANDROID_ABI}")
 set(LIB_CLASH_HEADER_PATH "${LIB_CLASH_INCLUDE_DIR}/libclash.h")
diff --git a/plugins/setup/buildkit/build_tool/lib/src/go_builder.dart b/plugins/setup/buildkit/build_tool/lib/src/go_builder.dart
index e2854260a..d58bf8c0a 100644
--- a/plugins/setup/buildkit/build_tool/lib/src/go_builder.dart
+++ b/plugins/setup/buildkit/build_tool/lib/src/go_builder.dart
@@ -12,6 +12,16 @@ import 'util.dart';
 
 final _log = Logger('go_builder');
 
+const _android16kPageSizeExtLdflags =
+    '-Wl,-z,max-page-size=16384 -Wl,-z,common-page-size=16384';
+
+String _resolveGoLdflags(Target target, BuildConfig config) {
+  if (target.goos != 'android' || !target.isLib) {
+    return config.goLdflags;
+  }
+  return '${config.goLdflags} -extldflags "$_android16kPageSizeExtLdflags"';
+}
+
 String _resolveCc(Target target) {
   final ndk = Environment.androidNdk;
   final prebuiltDir = Directory(
@@ -64,7 +74,7 @@ class GoBuilder {
 
     final args = [
       'build',
-      '-ldflags=${config.goLdflags}',
+      '-ldflags=${_resolveGoLdflags(target, config)}',
       '-tags=${config.tags}',
       if (target.isLib) '-buildmode=c-shared',
       '-o',
diff --git a/pubspec.lock b/pubspec.lock
index fbdaed33a..b3e3fc0c3 100755
--- a/pubspec.lock
+++ b/pubspec.lock
@@ -481,12 +481,11 @@ packages:
   flutter_js:
     dependency: "direct main"
     description:
-      path: "."
-      ref: master
-      resolved-ref: c0e10a5dab0e22cd616ec92ae71471d76369cbfe
-      url: "https://github.com/chen08209/flutter_js"
-    source: git
-    version: "0.8.3"
+      name: flutter_js
+      sha256: "046428059ac7bef71e305dc35fc24be933b684684a43e83eab7ebd0dc407ad85"
+      url: "https://pub.dev"
+    source: hosted
+    version: "0.8.7"
   flutter_lints:
     dependency: "direct dev"
     description:
diff --git a/pubspec.yaml b/pubspec.yaml
index 15ac08eaf..bd91a2317 100755
--- a/pubspec.yaml
+++ b/pubspec.yaml
@@ -62,10 +62,7 @@ dependencies:
   riverpod_annotation: ^4.0.2
   riverpod: ^3.2.1
   material_color_utilities: ^0.13.0
-  flutter_js:
-    git:
-      url: https://github.com/chen08209/flutter_js
-      ref: master
+  flutter_js: ^0.8.7
   flutter_svg: ^2.1.0
   flutter_cache_manager: ^3.4.1
   crypto: ^3.0.3
